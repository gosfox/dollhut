{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gosfox.github.io/dollhut/schemas/net.v1.schema.json",
  "title": "Nets",
  "description": "Full contents of nets.json, shared character collections",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "net_version", "name", "members"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^net_[a-zA-Z0-9]+$"
      },
      "net_version": {
        "type": "integer",
        "description": "ONLY net format version",
        "const": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "members": {
        "type": "array",
        "description": "Referenced characters, never copied data",
        "items": {
          "type": "object",
          "required": ["character_id", "manifest_url"],
          "additionalProperties": false,
          "properties": {
            "character_id": {
              "type": "string",
              "pattern": "^char_[a-zA-Z0-9]+$",
              "description": "May belong to this repo or another user"
            },
            "manifest_url": {
              "type": "string",
              "format": "uri",
              "description": "URL to the manifest.json of the character's actual owner. Used instead of an internal repo_id, since a repository can be unlinked, moved, or change owner without the reference breaking."
            },
            "added_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
  }
}